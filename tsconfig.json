{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "branch-kit.vercel.app_admin_1omdtw",
    "branch-kit.vercel.app_admin_1q3vwi",
    "workspace",
    "src/pages",
    "src/sections",
    "src/App.tsx",
    "src/index.tsx",
    "vite.config.ts",
    "tailwind.config.js",
    "tsconfig.app.json",
    "tsconfig.node.json"
  ]
}
